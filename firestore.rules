rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == "pavanmehta99550@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    // Admin access
    match /admins/{adminId} {
      // Allow any signed-in user to check if they specifically are an admin without permissions-denied crash
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Match users collection (private data per user)
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /{collectionPath}/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Custom accounts for multi-device sync without Google login
    match /custom_credentials/{username} {
      // Allow any user to find a credential to check password
      allow get: if true;
      // Allow creation of first-time credentials
      allow create: if true;
      // Allow update if they know the id (this is simplified as requested)
      allow update: if true;
    }

    match /custom_accounts/{customId} {
      allow read, write: if true;
      
      match /{collectionPath}/{docId} {
        allow read, write: if true;
      }
    }
  }
}
